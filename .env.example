# Copy this file to .env.development for local development
# Copy this file to .env.production for production builds

# Backend API base URL (include /api suffix)
# Local development:  http://localhost:8080/api
# Production EC2:     http://<EC2-IP>:8080/api
VITE_API_BASE_URL=http://98.130.107.197:8080/

# Set to true to use MSW mock service worker (dev only)
# Set to false when connecting to a real backend
VITE_ENABLE_MSW=false

# Environment label (development | production)
VITE_APP_ENV=development
